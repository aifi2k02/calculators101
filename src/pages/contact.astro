---
import Layout from '../layouts/Layout.astro'
const TURNSTILE_SITE_KEY = '0x4AAAAAADvI_JBa22IsjT8D'
---
<Layout
  title="Contact Us — Super Calculator"
  description="Get in touch with the Super Calculator team. Send us a message and we'll respond as soon as possible."
  canonical="https://supercalculator.xyz/contact"
>
  <script slot="head" is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="text-xs text-gray-500 mb-6 flex gap-1 items-center">
      <a href="/" class="hover:text-blue-600">Home</a><span>›</span>
      <span class="text-gray-900">Contact</span>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 mb-2">Contact Us</h1>
    <p class="text-gray-500 text-sm mb-8">Have a question, found a bug, or want to suggest a calculator? Fill out the form below and we'll get back to you.</p>

    <!-- Success message -->
    <div id="success-msg" class="hidden bg-green-50 border border-green-200 rounded-xl px-5 py-4 mb-6 text-sm text-green-800 flex items-start gap-3">
      <svg class="w-5 h-5 shrink-0 mt-0.5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
      </svg>
      <div>
        <p class="font-semibold">Message sent!</p>
        <p class="mt-0.5 text-green-700">Thanks for reaching out. We'll reply to your email within 1–2 business days.</p>
      </div>
    </div>

    <!-- Error message -->
    <div id="error-msg" class="hidden bg-red-50 border border-red-200 rounded-xl px-5 py-4 mb-6 text-sm text-red-800">
      Something went wrong. Please try emailing us directly at <a href="mailto:aifi2k02@gmail.com" class="underline font-medium">aifi2k02@gmail.com</a>.
    </div>

    <form id="contact-form" class="space-y-5">
      <div>
        <label for="name" class="block text-sm font-semibold text-gray-700 mb-1.5">Your Name <span class="text-red-500">*</span></label>
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder="Jane Smith"
          class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent shadow-sm"
        />
      </div>

      <div>
        <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">Email Address <span class="text-red-500">*</span></label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder="jane@example.com"
          class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent shadow-sm"
        />
      </div>

      <div>
        <label for="subject" class="block text-sm font-semibold text-gray-700 mb-1.5">Subject <span class="text-red-500">*</span></label>
        <select
          id="subject"
          name="subject"
          required
          class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white shadow-sm"
        >
          <option value="">Select a topic…</option>
          <option value="bug">Report a bug or wrong result</option>
          <option value="suggestion">Suggest a calculator</option>
          <option value="feedback">General feedback</option>
          <option value="business">Business / partnership inquiry</option>
          <option value="privacy">Privacy or data question</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div>
        <label for="message" class="block text-sm font-semibold text-gray-700 mb-1.5">Message <span class="text-red-500">*</span></label>
        <textarea
          id="message"
          name="message"
          required
          rows="5"
          placeholder="Describe your question or feedback in detail…"
          class="w-full px-4 py-2.5 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-y shadow-sm"
        ></textarea>
      </div>

      <!-- Cloudflare Turnstile widget -->
      <div>
        <div class="cf-turnstile" data-sitekey="0x4AAAAAADvI_JBa22IsjT8D" data-theme="light"></div>
        <p id="captcha-error" class="hidden mt-1.5 text-xs text-red-600">Please complete the security check before sending.</p>
      </div>

      <button
        type="submit"
        id="submit-btn"
        class="w-full bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-bold py-3 px-6 rounded-xl transition-all text-sm shadow-md shadow-blue-200 hover:shadow-lg hover:-translate-y-0.5 disabled:opacity-60 disabled:cursor-not-allowed disabled:translate-y-0"
      >
        Send Message
      </button>

      <p class="text-xs text-gray-400 text-center">
        Your message will be sent from <strong>supercalculator.xyz</strong> to our team inbox.
      </p>
    </form>

    <!-- Direct contact fallback -->
    <div class="mt-10 border-t border-gray-100 pt-8">
      <h2 class="text-sm font-semibold text-gray-900 mb-3">Prefer to email directly?</h2>
      <a
        href="mailto:aifi2k02@gmail.com?subject=Contact from supercalculator.xyz"
        class="inline-flex items-center gap-2 text-sm text-blue-600 hover:text-blue-800 font-medium"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        aifi2k02@gmail.com
      </a>
      <p class="text-xs text-gray-400 mt-1">We typically respond within 1–2 business days.</p>
    </div>
  </div>
</Layout>

<script>
  const WEB3FORMS_KEY = '148b0019-52c0-48c0-84eb-d9941161aac2'

  const form = document.getElementById('contact-form') as HTMLFormElement
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement
  const successMsg = document.getElementById('success-msg')
  const errorMsg = document.getElementById('error-msg')
  const captchaError = document.getElementById('captcha-error')

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    errorMsg?.classList.add('hidden')
    successMsg?.classList.add('hidden')
    captchaError?.classList.add('hidden')

    // Get Turnstile token
    const turnstileToken = (document.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement)?.value
    if (!turnstileToken) {
      captchaError?.classList.remove('hidden')
      return
    }

    submitBtn.disabled = true
    submitBtn.textContent = 'Sending…'

    const payload = {
      access_key: WEB3FORMS_KEY,
      from_name: 'Super Calculator Contact',
      subject: `[supercalculator.xyz] ${(document.getElementById('subject') as HTMLSelectElement).value}`,
      name: (document.getElementById('name') as HTMLInputElement).value,
      email: (document.getElementById('email') as HTMLInputElement).value,
      topic: (document.getElementById('subject') as HTMLSelectElement).value,
      message: (document.getElementById('message') as HTMLTextAreaElement).value,
      source: 'supercalculator.xyz',
      replyto: (document.getElementById('email') as HTMLInputElement).value,
      'cf-turnstile-response': turnstileToken,
    }

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(payload),
      })
      const json = await res.json()
      if (json.success) {
        form.reset()
        // Reset Turnstile widget
        if (typeof (window as any).turnstile !== 'undefined') {
          (window as any).turnstile.reset()
        }
        successMsg?.classList.remove('hidden')
        successMsg?.scrollIntoView({ behavior: 'smooth', block: 'nearest' })
      } else {
        throw new Error(json.message ?? 'Submission failed')
      }
    } catch {
      errorMsg?.classList.remove('hidden')
    } finally {
      submitBtn.disabled = false
      submitBtn.textContent = 'Send Message'
    }
  })
</script>
