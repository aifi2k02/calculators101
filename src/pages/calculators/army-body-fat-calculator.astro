---
import Layout from '../../layouts/Layout.astro'
import Calculator from '../../components/Calculator.astro'

const formulaFn = `
  const gender = inputs.gender || 'male'
  const height = parseFloat(inputs.height) || 0
  const neck = parseFloat(inputs.neck) || 0
  const waist = parseFloat(inputs.waist) || 0
  const hip = parseFloat(inputs.hip) || 0
  const age = parseInt(inputs.age) || 0
  if (height <= 0 || neck <= 0 || waist <= 0) throw new Error('Enter height, neck, and waist in inches.')
  let bf
  if (gender === 'female') {
    if (hip <= 0) throw new Error('Enter your hip measurement in inches.')
    if (waist + hip - neck <= 0) throw new Error('Check measurements: waist + hip must be greater than neck.')
    bf = 163.205 * Math.log10(waist + hip - neck) - 97.684 * Math.log10(height) - 78.387
  } else {
    if (waist - neck <= 0) throw new Error('Waist must be greater than neck.')
    bf = 86.010 * Math.log10(waist - neck) - 70.041 * Math.log10(height) + 36.76
  }
  bf = Math.max(0, bf)
  const std = gender === 'female'
    ? (age <= 20 ? 30 : age <= 27 ? 32 : age <= 39 ? 34 : 36)
    : (age <= 20 ? 20 : age <= 27 ? 22 : age <= 39 ? 24 : 26)
  const pass = bf <= std
  const margin = Math.abs(bf - std)
  return {
    value: bf.toFixed(1) + '% body fat',
    gaugeValue: Math.min(bf, 40),
    stats: [
      { label: 'Body Fat', value: bf.toFixed(1) + '%' },
      { label: 'Army Max (your age)', value: std + '%' },
      { label: 'Result', value: pass ? 'PASS' : 'OVER' },
      { label: pass ? 'Under limit by' : 'Over limit by', value: margin.toFixed(1) + '%' }
    ],
    breakdown: [
      'Method: U.S. military tape test (Hodgdon-Beckett circumference)',
      'Sex: ' + (gender === 'female' ? 'Female' : 'Male') + ', age ' + (age || '—'),
      'Height: ' + height + ' in',
      'Neck: ' + neck + ' in, Waist: ' + waist + ' in' + (gender === 'female' ? ', Hip: ' + hip + ' in' : ''),
      '—',
      'Estimated body fat: ' + bf.toFixed(1) + '%',
      'AR 600-9 maximum for your age/sex: ' + std + '%',
      pass ? 'Result: PASS — ' + margin.toFixed(1) + '% under the limit' : 'Result: OVER — ' + margin.toFixed(1) + '% above the limit'
    ],
    share: {
      kicker: 'US Army tape test (AR 600-9)',
      heroNumber: bf.toFixed(1) + '%',
      heroSub: 'body fat — ' + (pass ? 'PASS' : 'over the limit') + ' vs the ' + std + '% max for my age',
      hook: 'Estimated with the military neck-and-waist tape method. No scale needed.',
      chips: ['BF ' + bf.toFixed(1) + '%', 'Max ' + std + '%', pass ? 'PASS' : 'OVER']
    }
  }
`

const gauge = {
  min: 0, max: 40, unit: '%',
  zones: [
    { label: 'Lean', color: '#22c55e', from: 0, to: 15 },
    { label: 'Fit', color: '#3b82f6', from: 15, to: 24 },
    { label: 'Moderate', color: '#f59e0b', from: 24, to: 32 },
    { label: 'High', color: '#ef4444', from: 32, to: 40 },
  ]
}

const faqs = [
  { question: 'How does the Army body fat calculator work?', answer: 'It uses the U.S. military "tape test" (the Hodgdon-Beckett circumference method) from Army Regulation AR 600-9. For men it uses height, neck, and waist; for women it adds the hip measurement. A logarithmic formula estimates body fat percentage from those circumferences — no scale or calipers needed.' },
  { question: 'Where do I measure neck, waist, and hip?', answer: 'Neck: just below the larynx (Adam\'s apple), tape sloping slightly down at the front. Waist (men): horizontally at the navel. Waist (women): at the narrowest point. Hip (women only): at the widest point of the buttocks. Measure in inches, relaxed, without compressing the skin.' },
  { question: 'What are the Army body fat limits?', answer: 'Men: 20% (ages 17–20), 22% (21–27), 24% (28–39), 26% (40+). Women: 30% (17–20), 32% (21–27), 34% (28–39), 36% (40+). Stay at or below the limit for your age and sex to pass the AR 600-9 standard.' },
  { question: 'Is this the same as the Navy and Marine formula?', answer: 'Yes — the Army, Navy, Marines, and Air Force all use the same Hodgdon-Beckett circumference equations; only the pass/fail body-fat limits differ by branch. This calculator uses the formula and the Army AR 600-9 limits.' },
  { question: 'How accurate is the tape test?', answer: 'The circumference method is a screening estimate, typically within 3–4% of a DEXA or hydrostatic reading for most people. It can over-estimate for very muscular builds. It is designed for consistency and ease, not lab-grade precision.' },
]
---
<Layout
  title="Army Body Fat Calculator (AR 600-9 Tape Test) — Navy & Marine"
  description="Estimate your body fat with the U.S. military tape test (Hodgdon-Beckett method) and check the AR 600-9 pass limits by age. Free Army/Navy body fat calculator."
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Fitness & Health', href: '/calculators/fitness' },
    { name: 'Army Body Fat Calculator', href: '/calculators/army-body-fat-calculator' },
  ]}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <nav class="text-xs text-gray-500 mb-6 flex gap-1 items-center flex-wrap">
      <a href="/" class="hover:text-blue-600">Home</a><span>›</span>
      <a href="/calculators/fitness" class="hover:text-blue-600">Fitness &amp; Health</a><span>›</span>
      <span class="text-gray-900">Army Body Fat Calculator</span>
    </nav>
    <div class="grid lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <Calculator
          title="Army Body Fat Calculator (AR 600-9)"
          description="Military tape-test body fat estimate and pass/fail by age"
          formulaId="army-body-fat"
          formulaFn={formulaFn}
          resultLabel="Estimated Body Fat"
          shareStyle="time"
          inputs={[
            { id: 'gender', label: 'Sex', type: 'select', options: [
              { value: 'male', label: 'Male' },
              { value: 'female', label: 'Female' },
            ], defaultValue: 'male' },
            { id: 'age', label: 'Age', type: 'number', placeholder: '25', min: 17, max: 80, unit: 'yrs', defaultValue: 25 },
            { id: 'height', label: 'Height', type: 'number', placeholder: '70', min: 0, step: 0.1, unit: 'in', defaultValue: 70 },
            { id: 'neck', label: 'Neck Circumference', type: 'number', placeholder: '15.5', min: 0, step: 0.1, unit: 'in', defaultValue: 15.5 },
            { id: 'waist', label: 'Waist Circumference', type: 'number', placeholder: '34', min: 0, step: 0.1, unit: 'in', defaultValue: 34 },
            { id: 'hip', label: 'Hip Circumference (females only)', type: 'number', placeholder: '0', min: 0, step: 0.1, unit: 'in', defaultValue: 0 },
          ]}
          gauge={gauge}
          intro="This Army body fat calculator uses the official U.S. military tape test — the Hodgdon-Beckett circumference method behind AR 600-9 — to estimate your body fat percentage from your height, neck, and waist (plus hip for women). It then checks the result against the Army's maximum body-fat limit for your age and sex."
          disclaimer="Screening estimate only — the circumference method can over-estimate for very muscular builds and is not a substitute for DEXA or an official measurement. The same formula is used by the Navy, Marines, and Air Force; only the pass limits differ."
          lastUpdated="2026-07-18"
          faqs={faqs}
          relatedCalcs={[
            { name: 'Body Fat Calculator', href: '/calculators/body-fat-calculator' },
            { name: 'BMI Calculator', href: '/calculators/bmi-calculator' },
            { name: 'Lean Body Mass', href: '/calculators/lean-body-mass-calculator' },
            { name: 'Ideal Weight', href: '/calculators/ideal-weight-calculator' },
            { name: 'BMR Calculator', href: '/calculators/bmr-calculator' },
            { name: 'Waist-to-Hip Ratio', href: '/calculators/waist-hip-calculator' },
          ]}
        />
      </div>
      <aside class="space-y-5">
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-5">
          <h3 class="font-bold text-blue-900 mb-3">Army Max Body Fat</h3>
          <table class="w-full text-xs text-blue-800">
            <thead><tr class="text-blue-500"><th class="text-left pb-1">Age</th><th class="text-right pb-1">Male</th><th class="text-right pb-1">Female</th></tr></thead>
            <tbody>
              {[['17–20','20%','30%'],['21–27','22%','32%'],['28–39','24%','34%'],['40+','26%','36%']].map(([a,m,f]) => (
                <tr class="border-t border-blue-100"><td class="py-1 font-medium">{a}</td><td class="py-1 text-right">{m}</td><td class="py-1 text-right">{f}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-5">
          <h3 class="font-bold text-gray-900 text-sm mb-2">How to measure</h3>
          <ul class="space-y-1.5 text-xs text-gray-600 list-disc pl-4">
            <li><strong>Neck:</strong> below the larynx, tape sloping down</li>
            <li><strong>Waist (M):</strong> horizontal at the navel</li>
            <li><strong>Waist (F):</strong> at the narrowest point</li>
            <li><strong>Hip (F):</strong> at the widest point</li>
            <li>Relax; don't compress the skin</li>
          </ul>
        </div>
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
          <h3 class="font-semibold text-amber-900 text-sm mb-1">All branches, one formula</h3>
          <p class="text-xs text-amber-800">Army, Navy, Marines &amp; Air Force share the Hodgdon-Beckett equations — only the pass limits differ.</p>
        </div>
      </aside>
    </div>
  </div>
</Layout>
