---
import Layout from '../../layouts/Layout.astro'
import Calculator from '../../components/Calculator.astro'

const formulaFn = `
  const principal = parseFloat(inputs.principal) || 0
  const rate = parseFloat(inputs.rate) || 0
  const years = parseFloat(inputs.years) || 0
  const n = parseInt(inputs.n) || 12
  const monthly = parseFloat(inputs.monthly) || 0
  if (years <= 0) throw new Error('Time period must be greater than 0.')
  const r = rate / 100
  const fvLump = principal * Math.pow(1 + r / n, n * years)
  const fvContrib = monthly > 0 ? monthly * (Math.pow(1 + r / n, n * years) - 1) / (r / n) : 0
  const total = fvLump + fvContrib
  const totalContrib = principal + monthly * 12 * years
  const interest = total - totalContrib
  const growthPct = totalContrib > 0 ? ((total - totalContrib) / totalContrib) * 100 : 0
  return {
    value: '$' + total.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }),
    gaugeValue: Math.min(growthPct, 500),
    breakdown: [
      'Total contributions: $' + totalContrib.toLocaleString('en-US', { maximumFractionDigits: 0 }),
      'Interest earned: $' + interest.toLocaleString('en-US', { maximumFractionDigits: 0 }),
      'Growth: ' + growthPct.toFixed(1) + '%',
    ],
    stats: [
      { label: 'Future Value', value: '$' + total.toLocaleString('en-US', { maximumFractionDigits: 0 }) },
      { label: 'Interest Earned', value: '$' + interest.toLocaleString('en-US', { maximumFractionDigits: 0 }) },
      { label: 'Total Contributed', value: '$' + totalContrib.toLocaleString('en-US', { maximumFractionDigits: 0 }) },
      { label: 'Growth %', value: growthPct.toFixed(1) + '%' },
    ]
  }
`

const faqs = [
  { question: 'What is compound interest?', answer: 'Compound interest is interest calculated on both the initial principal and the accumulated interest from previous periods. Unlike simple interest, it grows exponentially — your earnings generate their own earnings over time.' },
  { question: 'How often should interest compound?', answer: 'More frequent compounding means more growth. Monthly compounding yields slightly more than quarterly or annually. Most savings accounts compound monthly or daily. The difference between monthly and daily compounding is usually small.' },
  { question: 'What is the Rule of 72?', answer: 'Divide 72 by your annual interest rate to estimate years to double your money. At 7% annual return, your investment doubles in roughly 72 ÷ 7 = 10.3 years.' },
  { question: 'How do monthly contributions affect growth?', answer: 'Regular monthly contributions dramatically accelerate wealth. Adding $200/month to a $10,000 investment at 7% over 30 years grows to ~$354k vs. ~$76k without contributions — nearly 5× more wealth from consistent saving.' },
  { question: 'What is a realistic investment return?', answer: 'The S&P 500 has historically returned ~10% annually before inflation, or ~7% after. For conservative planning, use 5–7%; for stock-heavy long-horizon portfolios, 7–10% is reasonable.' },
]
---

<Layout
  title="Compound Interest Calculator: Grow Your Investment Over Time"
  description="Calculate compound interest with monthly contributions. See exactly how much your money grows with our free compound interest calculator."
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Financial', href: '/calculators/financial' },
    { name: 'Compound Interest Calculator', href: '/calculators/compound-interest-calculator' },
  ]}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <nav class="text-xs text-gray-500 mb-6 flex gap-1 items-center flex-wrap">
      <a href="/" class="hover:text-blue-600">Home</a><span>›</span>
      <a href="/calculators/financial" class="hover:text-blue-600">Financial</a><span>›</span>
      <span class="text-gray-900">Compound Interest Calculator</span>
    </nav>
    <div class="grid lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <Calculator
          title="Compound Interest Calculator"
          description="See how your investments grow over time with the power of compounding"
          formulaId="compound-interest"
          formulaFn={formulaFn}
          resultLabel="Future Value"
          inputs={[
            { id: 'principal', label: 'Initial Investment', type: 'number', placeholder: '10000', min: 0, unit: '$', defaultValue: 10000 },
            { id: 'rate', label: 'Annual Interest Rate', type: 'number', placeholder: '7', min: 0, max: 100, step: 0.1, unit: '%', defaultValue: 7 },
            { id: 'years', label: 'Time Period', type: 'number', placeholder: '10', min: 1, max: 50, unit: 'years', defaultValue: 10 },
            { id: 'n', label: 'Compounding Frequency', type: 'select', options: [
              { value: '12', label: 'Monthly' },
              { value: '4', label: 'Quarterly' },
              { value: '2', label: 'Semi-annually' },
              { value: '1', label: 'Annually' },
              { value: '365', label: 'Daily' },
            ], defaultValue: '12' },
            { id: 'monthly', label: 'Monthly Contribution', type: 'number', placeholder: '0', min: 0, unit: '$', defaultValue: 0 },
          ]}
          gauge={{
            min: 0, max: 500, clampMax: 500, unit: '% growth',
            zones: [
              { label: 'Minimal', color: '#94a3b8', from: 0, to: 50 },
              { label: 'Moderate', color: '#3b82f6', from: 50, to: 150 },
              { label: 'Good', color: '#22c55e', from: 150, to: 300 },
              { label: 'Excellent', color: '#f59e0b', from: 300, to: 500 },
            ]
          }}
          faqs={faqs}
          relatedCalcs={[
            { name: 'Savings Calculator', href: '/calculators/savings-calculator' },
            { name: 'Retirement Calculator', href: '/calculators/retirement-calculator' },
            { name: 'Investment Calculator', href: '/calculators/investment-calculator' },
            { name: 'Rule of 72 Calculator', href: '/calculators/rule-of-72-calculator' },
          ]}
        />
      </div>
      <aside class="space-y-5">
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-5">
          <h3 class="font-bold text-blue-900 mb-3">Growth at 7% Annual Return</h3>
          <table class="w-full text-xs">
            <thead><tr class="text-blue-700"><th class="text-left pb-1">Years</th><th class="text-right pb-1">$10k lump</th><th class="text-right pb-1">+$200/mo</th></tr></thead>
            <tbody class="text-blue-900">
              {[['10', '$19,672', '$54,304'], ['20', '$38,697', '$156,384'], ['30', '$76,123', '$354,435']].map(r => (
                <tr class="border-t border-blue-100"><td class="py-1">{r[0]}</td><td class="text-right">{r[1]}</td><td class="text-right">{r[2]}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-5">
          <h3 class="font-bold text-gray-900 mb-3">The Formula</h3>
          <div class="bg-gray-50 rounded-lg p-3 text-xs font-mono text-gray-700 mb-2">A = P(1 + r/n)^(nt)</div>
          <ul class="text-xs text-gray-600 space-y-1">
            <li><strong>A</strong> = future value</li>
            <li><strong>P</strong> = principal</li>
            <li><strong>r</strong> = annual rate (decimal)</li>
            <li><strong>n</strong> = compounds per year</li>
            <li><strong>t</strong> = years</li>
          </ul>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-xl p-5">
          <h3 class="font-bold text-green-900 mb-2">Start Early</h3>
          <p class="text-xs text-green-800">Investing $5,000/yr from age 25–35 (just 10 years, $50k total) at 7% grows to <strong>~$602k by 65</strong>. Starting at 35 and contributing every year until 65 ($150k total) only reaches ~$540k. Time beats money.</p>
        </div>
      </aside>
    </div>

    <div class="mt-12 grid md:grid-cols-2 gap-8">
      <div>
        <h2 class="text-xl font-bold text-gray-900 mb-4">How Compound Interest Works</h2>
        <p class="text-gray-600 text-sm mb-3">Compound interest earns on both your principal and accumulated past interest. Each period, interest is added to your balance, and future interest calculations include that amount — creating exponential growth.</p>
        <div class="grid grid-cols-2 gap-3 mt-4">
          {[
            { label: 'Simple Interest', detail: 'Earns on principal only. $10k at 7% = $700/yr, flat forever.' },
            { label: 'Compound Interest', detail: 'Earns on principal + interest. Growth accelerates each year.' },
            { label: 'More Frequent', detail: 'Daily > monthly > quarterly > annually for the same rate.' },
            { label: 'Time is Key', detail: 'Doubling your time horizon more than doubles your final wealth.' },
          ].map(c => (
            <div class="bg-gray-50 rounded-lg p-3">
              <div class="font-semibold text-gray-800 text-xs mb-1">{c.label}</div>
              <div class="text-xs text-gray-600">{c.detail}</div>
            </div>
          ))}
        </div>
      </div>
      <div>
        <h2 class="text-xl font-bold text-gray-900 mb-4">Compounding Frequency: $10k at 7% for 10 Years</h2>
        <table class="w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <thead class="bg-gray-50"><tr>
            <th class="text-left p-3 text-xs font-semibold text-gray-700">Frequency</th>
            <th class="text-right p-3 text-xs font-semibold text-gray-700">Future Value</th>
            <th class="text-right p-3 text-xs font-semibold text-gray-700">vs Annual</th>
          </tr></thead>
          <tbody class="divide-y divide-gray-100">
            {[['Annual','$19,672','—'],['Quarterly','$19,799','+$127'],['Monthly','$20,097','+$425'],['Daily','$20,136','+$464']].map(r => (
              <tr><td class="p-3 text-xs">{r[0]}</td><td class="p-3 text-xs text-right font-medium">{r[1]}</td><td class="p-3 text-xs text-right text-green-600">{r[2]}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>
