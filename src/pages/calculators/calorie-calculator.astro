---
import Layout from '../../layouts/Layout.astro'
import Calculator from '../../components/Calculator.astro'

const formulaFn = `
  const unit = inputs.unit
  const sex = inputs.sex
  const activity = parseFloat(inputs.activity)
  const goal = inputs.goal
  let weight = parseFloat(inputs.weight)
  let height = parseFloat(inputs.height)
  const age = parseFloat(inputs.age)
  if (isNaN(weight)||isNaN(height)||isNaN(age)||weight<=0||height<=0||age<=0)
    throw new Error('Please enter valid weight, height, and age.')
  if (unit === 'imperial') { weight = weight * 0.453592; height = height * 2.54 }
  let bmr
  if (sex === 'male') bmr = 10 * weight + 6.25 * height - 5 * age + 5
  else bmr = 10 * weight + 6.25 * height - 5 * age - 161
  const tdee = bmr * activity
  let target = tdee, goalLabel = 'Maintain weight'
  if (goal === 'lose_slow') { target = tdee - 250; goalLabel = 'Lose 0.5 lb/week' }
  else if (goal === 'lose_fast') { target = tdee - 500; goalLabel = 'Lose 1 lb/week' }
  else if (goal === 'lose_extreme') { target = tdee - 1000; goalLabel = 'Lose 2 lbs/week (aggressive)' }
  else if (goal === 'gain_slow') { target = tdee + 250; goalLabel = 'Gain 0.5 lb/week' }
  else if (goal === 'gain_fast') { target = tdee + 500; goalLabel = 'Gain 1 lb/week' }
  target = Math.max(1200, target)
  const protein = Math.round(weight * 2.2)
  const fat = Math.round(target * 0.25 / 9)
  const carbs = Math.round((target - protein * 4 - fat * 9) / 4)
  return {
    value: Math.round(target) + ' cal/day',
    stats: [
      { label: 'BMR', value: Math.round(bmr) + ' cal' },
      { label: 'TDEE', value: Math.round(tdee) + ' cal' },
      { label: 'Protein', value: protein + 'g' },
      { label: 'Carbs', value: carbs + 'g' },
      { label: 'Fat', value: fat + 'g' },
    ],
    breakdown: [
      'Goal: ' + goalLabel,
      'BMR (Mifflin-St Jeor): ' + Math.round(bmr) + ' cal/day',
      'Activity multiplier: ' + activity + 'x → TDEE ' + Math.round(tdee) + ' cal/day',
      'Calorie target: ' + Math.round(target) + ' cal/day',
      '—',
      'Macro split (suggested):',
      'Protein: ' + protein + 'g/day (' + Math.round(protein*4) + ' cal, 30%)',
      'Fat: ' + fat + 'g/day (' + Math.round(fat*9) + ' cal, 25%)',
      'Carbs: ' + carbs + 'g/day (' + Math.round(carbs*4) + ' cal, 45%)',
    ]
  }
`

const gauge = {
  min: 1000, max: 4000, unit: 'cal/day',
  zones: [
    { label: 'Low', color: '#3b82f6', from: 1000, to: 1500 },
    { label: 'Moderate', color: '#22c55e', from: 1500, to: 2500 },
    { label: 'Active', color: '#f59e0b', from: 2500, to: 3500 },
    { label: 'Very Active', color: '#ef4444', from: 3500, to: 4000 },
  ]
}
---
<Layout
  title="Calorie Calculator: Daily Calorie Needs for Any Goal"
  description="Calculate your daily calorie needs for weight loss, maintenance, or muscle gain using the Mifflin-St Jeor formula. Includes full macro breakdown."
  breadcrumbs={[{name:"Home",href:"/"},{name:"Fitness & Health",href:"/calculators/fitness"},{name:"Calorie Calculator",href:"/calculators/calorie-calculator"}]}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <nav class="text-xs text-gray-500 mb-6 flex gap-1 items-center flex-wrap">
      <a href="/" class="hover:text-blue-600">Home</a><span>›</span>
      <a href="/calculators/fitness" class="hover:text-blue-600">Fitness & Health</a><span>›</span>
      <span class="text-gray-900">Calorie Calculator</span>
    </nav>
    <div class="grid lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <Calculator
          title="Calorie Calculator"
          description="Daily calorie needs for any goal — Mifflin-St Jeor formula"
          formulaId="calorie"
          formulaFn={formulaFn}
          resultLabel="Daily Calorie Target"
          inputs={[
            { id: 'unit', label: 'Units', type: 'select', options: [
              { value: 'imperial', label: 'Imperial (lbs, inches)' },
              { value: 'metric', label: 'Metric (kg, cm)' },
            ], defaultValue: 'imperial' },
            { id: 'sex', label: 'Biological Sex', type: 'select', options: [
              { value: 'male', label: 'Male' }, { value: 'female', label: 'Female' },
            ], defaultValue: 'male' },
            { id: 'age', label: 'Age', type: 'number', placeholder: '30', min: 15, max: 100, defaultValue: 30 },
            { id: 'weight', label: 'Weight (lbs or kg)', type: 'number', placeholder: '170', min: 1, defaultValue: 170 },
            { id: 'height', label: 'Height (inches or cm)', type: 'number', placeholder: '70', min: 1, defaultValue: 70 },
            { id: 'activity', label: 'Activity Level', type: 'select', options: [
              { value: '1.2', label: 'Sedentary (desk job, little exercise)' },
              { value: '1.375', label: 'Lightly active (1–3 workouts/week)' },
              { value: '1.55', label: 'Moderately active (3–5 workouts/week)' },
              { value: '1.725', label: 'Very active (6–7 days/week)' },
              { value: '1.9', label: 'Extra active (physical job + daily training)' },
            ], defaultValue: '1.375' },
            { id: 'goal', label: 'Goal', type: 'select', options: [
              { value: 'maintain', label: 'Maintain weight' },
              { value: 'lose_slow', label: 'Lose 0.5 lb/week (mild deficit)' },
              { value: 'lose_fast', label: 'Lose 1 lb/week (moderate deficit)' },
              { value: 'lose_extreme', label: 'Lose 2 lbs/week (aggressive deficit)' },
              { value: 'gain_slow', label: 'Gain 0.5 lb/week (lean bulk)' },
              { value: 'gain_fast', label: 'Gain 1 lb/week (bulk)' },
            ], defaultValue: 'maintain' },
          ]}
          gauge={gauge}
          relatedCalcs={[
            { name: 'BMI Calculator', href: '/calculators/bmi-calculator' },
            { name: 'TDEE Calculator', href: '/calculators/tdee-calculator' },
            { name: 'Macro Calculator', href: '/calculators/macro-calculator' },
            { name: 'Caloric Deficit Calculator', href: '/calculators/caloric-deficit-calculator' },
            { name: 'BMR Calculator', href: '/calculators/bmr-calculator' },
            { name: 'Keto Calculator', href: '/calculators/keto-calculator' },
          ]}
          faqs={[
            { question: 'What formula does this calorie calculator use?', answer: 'The Mifflin-St Jeor equation, validated in 2005 by the Academy of Nutrition and Dietetics as the most accurate for estimating BMR in most adults. BMR × activity factor = TDEE (total daily energy expenditure).' },
            { question: 'How many calories should I eat to lose weight?', answer: 'A deficit of 500 calories/day creates ~1 lb/week of fat loss (since 1 lb fat ≈ 3,500 calories). A 250 cal/day deficit = 0.5 lb/week, which is more sustainable long-term. Never go below 1,200 cal/day (women) or 1,500 cal/day (men) without medical supervision.' },
            { question: 'What is BMR vs TDEE?', answer: 'BMR (Basal Metabolic Rate) is the calories your body burns at complete rest — just to maintain organ function. TDEE (Total Daily Energy Expenditure) multiplies BMR by your activity level to get what you actually burn each day.' },
            { question: 'How many calories do I need to gain muscle?', answer: 'A surplus of 250–500 cal/day is ideal for lean muscle gain ("clean bulk"). Larger surpluses lead to more fat gain. Combine with sufficient protein (1.6–2.2g per kg of bodyweight) and progressive resistance training.' },
            { question: 'Why does my calorie need change over time?', answer: 'As you lose weight, your BMR decreases (less mass to maintain). As you build muscle, it increases. TDEE also changes if your activity level changes. Recalculate every 4–6 weeks or after significant weight changes.' },
          ]}
        />
      </div>
      <div class="space-y-5">
        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
          <div class="bg-gray-50 px-4 py-3 border-b border-gray-200">
            <h3 class="font-semibold text-gray-800 text-sm">Typical Daily Calorie Needs</h3>
          </div>
          <table class="w-full text-xs">
            <thead><tr class="border-b border-gray-100">
              <th class="text-left px-4 py-2 text-gray-500 font-medium">Profile</th>
              <th class="text-right px-4 py-2 text-gray-500 font-medium">Calories</th>
            </tr></thead>
            <tbody>
              {[
                ['Sedentary woman (30)', '1,600–1,800'],
                ['Active woman (30)', '2,000–2,200'],
                ['Sedentary man (30)', '2,000–2,200'],
                ['Active man (30)', '2,600–2,900'],
                ['Weight loss (woman)', '1,200–1,500'],
                ['Weight loss (man)', '1,500–1,800'],
                ['Athlete (intensive)', '3,000–5,000+'],
              ].map(([p,c]) => (
                <tr class="border-b border-gray-50">
                  <td class="px-4 py-2 text-gray-700">{p}</td>
                  <td class="px-4 py-2 text-right font-semibold text-gray-900">{c}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-xl p-4">
          <h3 class="font-semibold text-green-900 text-sm mb-2">Calorie Deficit Math</h3>
          <div class="space-y-1 text-xs text-green-800">
            <div class="flex justify-between"><span>−250 cal/day</span><span>~0.5 lb/week</span></div>
            <div class="flex justify-between"><span>−500 cal/day</span><span>~1 lb/week</span></div>
            <div class="flex justify-between"><span>−750 cal/day</span><span>~1.5 lbs/week</span></div>
            <div class="flex justify-between"><span>−1000 cal/day</span><span>~2 lbs/week</span></div>
          </div>
          <p class="text-xs text-green-700 mt-2">1 lb fat ≈ 3,500 calories</p>
        </div>
      </div>
    </div>

    <!-- Rich content -->
    <div class="mt-16 max-w-3xl space-y-10">
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-3">How Many Calories Do You Need?</h2>
        <p class="text-gray-600 leading-relaxed mb-3">Your daily calorie needs depend on your Basal Metabolic Rate (BMR) — the energy your body requires at complete rest — multiplied by how active you are. This total is called TDEE (Total Daily Energy Expenditure).</p>
        <p class="text-gray-600 leading-relaxed">Eating at your TDEE maintains your current weight. Eating below it causes weight loss; eating above it causes weight gain. The relationship is roughly linear: every 3,500 calorie deficit equals 1 pound of fat loss.</p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-3">The Mifflin-St Jeor Formula</h2>
        <p class="text-gray-600 leading-relaxed mb-4">This calculator uses the Mifflin-St Jeor equation, recommended by the Academy of Nutrition and Dietetics as the most accurate for most adults:</p>
        <div class="bg-gray-50 rounded-xl p-5 border border-gray-200 space-y-3">
          <div>
            <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Men</p>
            <p class="font-mono text-sm text-gray-800">BMR = (10 × weight kg) + (6.25 × height cm) − (5 × age) + 5</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Women</p>
            <p class="font-mono text-sm text-gray-800">BMR = (10 × weight kg) + (6.25 × height cm) − (5 × age) − 161</p>
          </div>
          <div class="border-t border-gray-200 pt-3">
            <p class="text-xs text-gray-500 mb-1 font-medium uppercase tracking-wide">Then multiply by activity factor</p>
            <p class="font-mono text-sm text-gray-800">TDEE = BMR × Activity Factor (1.2 – 1.9)</p>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-3">Activity Level Guide</h2>
        <div class="space-y-2">
          {[
            ['1.2 — Sedentary', 'Desk job, no exercise. Walking around the house and office counts as activity.'],
            ['1.375 — Lightly Active', 'Light exercise or sports 1–3 days per week. Typical for someone who goes to the gym a couple times a week.'],
            ['1.55 — Moderately Active', 'Moderate exercise or sports 3–5 days per week. Most gym-goers fall here.'],
            ['1.725 — Very Active', 'Hard exercise or sports 6–7 days per week.'],
            ['1.9 — Extra Active', 'Very hard exercise, physical labor job, or training twice per day.'],
          ].map(([level, desc]) => (
            <div class="flex gap-3 bg-gray-50 rounded-lg p-3 border border-gray-100">
              <span class="font-semibold text-sm text-blue-700 shrink-0 w-36">{level}</span>
              <span class="text-sm text-gray-600">{desc}</span>
            </div>
          ))}
        </div>
      </section>
    </div>
  </div>
</Layout>
