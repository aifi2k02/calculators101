---
import Layout from '../../layouts/Layout.astro'
import CalcIcon from '../../components/CalcIcon.astro'
import { getCategoryBySlug } from '../../lib/calculators'

const cat = getCategoryBySlug('financial')!
---

<Layout
  title="Financial Calculators"
  description={cat.metaDescription}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- Breadcrumb -->
    <nav class="text-xs text-gray-500 mb-6 flex gap-1 items-center" aria-label="Breadcrumb">
      <a href="/" class="hover:text-blue-600">Home</a>
      <span>›</span>
      <span class="text-gray-900">Financial Calculators</span>
    </nav>

    <!-- H1 + intro -->
    <div class="mb-10">
      <div class="flex items-center gap-4 mb-3">
        <div class="w-16 h-16 rounded-2xl bg-blue-600 flex items-center justify-center shadow-md shadow-blue-200">
          <CalcIcon icon={cat.icon} size={32} class="text-white" />
        </div>
        <h1 class="text-3xl font-bold text-gray-900">{cat.name} Calculators</h1>
      </div>
      <p class="text-gray-600 max-w-2xl leading-relaxed">{cat.intro}</p>
    </div>

    <!-- Calculator grid -->
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-gray-800 mb-4">Available Calculators</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {cat.calculators.map(calc => (
          <a
            href={calc.href}
            class="bg-white border border-gray-200 hover:border-blue-300 hover:shadow-md rounded-xl p-5 transition-all group"
          >
            <div class="flex items-start gap-3">
              <div class="w-12 h-12 rounded-2xl bg-blue-600 group-hover:bg-blue-700 flex items-center justify-center shrink-0 transition-colors shadow-sm shadow-blue-200">
                <CalcIcon icon={calc.icon} size={22} class="text-white" />
              </div>
              <div>
                <div class="font-semibold text-gray-900 group-hover:text-blue-700 text-sm mb-1">{calc.name}</div>
                <div class="text-xs text-gray-500 leading-relaxed">{calc.description}</div>
              </div>
            </div>
          </a>
        ))}
        <!-- Coming soon placeholder -->
        <div class="bg-gray-50 border border-dashed border-gray-300 rounded-xl p-5 flex items-center justify-center">
          <p class="text-xs text-gray-400 text-center">More calculators coming soon</p>
        </div>
      </div>
    </section>

    <!-- Related categories -->
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-gray-800 mb-4">Other Categories</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        <a href="/calculators/fitness" class="bg-green-50 border border-green-200 hover:border-green-400 rounded-xl p-4 text-sm font-medium text-green-800 hover:text-green-900 transition-colors flex items-center gap-2"><CalcIcon icon="🏃" size={16} class="text-green-700" /> Fitness & Health</a>
        <a href="/calculators/math" class="bg-purple-50 border border-purple-200 hover:border-purple-400 rounded-xl p-4 text-sm font-medium text-purple-800 hover:text-purple-900 transition-colors flex items-center gap-2"><CalcIcon icon="📐" size={16} class="text-purple-700" /> Math</a>
        <a href="/calculators/other" class="bg-amber-50 border border-amber-200 hover:border-amber-400 rounded-xl p-4 text-sm font-medium text-amber-800 hover:text-amber-900 transition-colors flex items-center gap-2"><CalcIcon icon="⚙️" size={16} class="text-amber-700" /> Other</a>
      </div>
    </section>

    <!-- FAQ -->
    <section class="max-w-2xl">
      <h2 class="text-lg font-semibold text-gray-800 mb-4">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {cat.faqs.map(faq => (
          <details class="bg-white border border-gray-200 rounded-lg px-4 py-3 group">
            <summary class="text-sm font-medium text-gray-800 cursor-pointer list-none flex justify-between items-center">
              {faq.question}
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <p class="mt-2 text-sm text-gray-600 leading-relaxed">{faq.answer}</p>
          </details>
        ))}
      </div>
    </section>
  </div>
</Layout>

<!-- BreadcrumbList schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://supercalculator.xyz/" },
    { "@type": "ListItem", "position": 2, "name": "Financial Calculators", "item": "https://supercalculator.xyz/calculators/financial" }
  ]
})} />
