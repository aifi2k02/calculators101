---
import Layout from '../layouts/Layout.astro'
import CalcIcon from '../components/CalcIcon.astro'
import { categories } from '../lib/calculators'
import siteConfig from '../lib/siteConfig'

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteConfig.siteName,
  url: siteConfig.siteUrl,
  description: siteConfig.siteDescription,
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${siteConfig.siteUrl}/?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
}

const popularCalcs = [
  { name: 'Mortgage Calculator', href: '/calculators/mortgage-calculator', icon: '🏠' },
  { name: 'BMI Calculator', href: '/calculators/bmi-calculator', icon: '⚖️' },
  { name: 'Tip Calculator', href: '/calculators/tip-calculator', icon: '🍽️' },
  { name: 'Age Calculator', href: '/calculators/age-calculator', icon: '🎂' },
  { name: 'Percentage Calculator', href: '/calculators/percentage-calculator', icon: '📊' },
  { name: 'Compound Interest', href: '/calculators/compound-interest-calculator', icon: '📈' },
  { name: 'Calorie Calculator', href: '/calculators/calorie-calculator', icon: '🥗' },
  { name: 'Loan Calculator', href: '/calculators/loan-calculator', icon: '💳' },
  { name: 'GPA Calculator', href: '/calculators/gpa-calculator', icon: '🎓' },
  { name: 'Date Calculator', href: '/calculators/date-calculator', icon: '📅' },
]

const colorMap: Record<string, string> = {
  blue: 'bg-blue-50 border-blue-200 hover:border-blue-400',
  green: 'bg-green-50 border-green-200 hover:border-green-400',
  purple: 'bg-purple-50 border-purple-200 hover:border-purple-400',
  amber: 'bg-amber-50 border-amber-200 hover:border-amber-400',
}

// Only show live calculators in search
const allCalcs = categories.flatMap(c => c.calculators.filter(calc => calc.live))
---

<Layout
  title="Super Calculator — Free Online Calculators for Everything"
  description="Super Calculator: 135+ free online calculators for finance, fitness, math, and everyday life. Mortgage, BMI, calorie, loan, TDEE, and more — fast, accurate, no sign-up."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-blue-600 via-blue-700 to-indigo-800 text-white py-20 px-4">
    <!-- decorative blobs -->
    <div class="absolute -top-20 -left-20 w-80 h-80 bg-blue-500/30 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-20 -right-20 w-96 h-96 bg-indigo-500/30 rounded-full blur-3xl pointer-events-none"></div>
    <div class="relative max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-white/15 border border-white/25 rounded-full px-4 py-1.5 text-xs font-semibold mb-6 backdrop-blur-sm">
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
        135+ free calculators — no sign-up required
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold mb-5 leading-tight tracking-tight">
        Super Calculator<br class="hidden sm:block" />
        <span class="text-blue-200">for Everything</span>
      </h1>
      <p class="text-blue-100 text-lg sm:text-xl mb-10 max-w-2xl mx-auto leading-relaxed">
        Fast, accurate calculators for finance, fitness, math, and everyday life. No ads. Just results.
      </p>
      <div class="max-w-lg mx-auto relative">
        <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
          <svg class="w-5 h-5 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </div>
        <input
          id="hero-search"
          type="text"
          placeholder="Search calculators..."
          class="w-full pl-12 pr-5 py-4 rounded-2xl text-white placeholder-white/60 bg-white/20 border border-white/30 text-sm focus:outline-none focus:ring-2 focus:ring-white/50 focus:bg-white/25 shadow-xl backdrop-blur-sm transition-all"
          autocomplete="off"
          aria-label="Search calculators"
        />
        <div id="search-dropdown" class="hidden absolute top-full left-0 right-0 mt-2 bg-white rounded-2xl shadow-2xl border border-gray-100 z-50 max-h-64 overflow-y-auto" role="listbox"></div>
      </div>
    </div>
  </section>

  <!-- Stats strip -->
  <div class="bg-white border-b border-gray-100 shadow-sm">
    <div class="max-w-4xl mx-auto px-4 py-4 grid grid-cols-3 divide-x divide-gray-100 text-center">
      <div class="px-4">
        <div class="text-2xl font-extrabold text-blue-600">135+</div>
        <div class="text-xs text-gray-500 font-medium mt-0.5">Calculators</div>
      </div>
      <div class="px-4">
        <div class="text-2xl font-extrabold text-green-600">Free</div>
        <div class="text-xs text-gray-500 font-medium mt-0.5">No sign-up</div>
      </div>
      <div class="px-4">
        <div class="text-2xl font-extrabold text-amber-500">Instant</div>
        <div class="text-xs text-gray-500 font-medium mt-0.5">Results</div>
      </div>
    </div>
  </div>

  <!-- Most Popular -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="flex items-center gap-3 mb-6">
      <h2 class="text-xl font-bold text-gray-900">Most Popular</h2>
      <span class="text-xs bg-blue-100 text-blue-700 font-semibold px-2.5 py-1 rounded-full">Top picks</span>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
      {popularCalcs.map(calc => (
        <a
          href={calc.href}
          class="bg-white border border-gray-200 hover:border-blue-400 hover:shadow-lg hover:-translate-y-0.5 rounded-2xl p-4 text-center transition-all duration-200 group"
        >
          <div class="flex justify-center mb-3">
            <div class="w-14 h-14 rounded-2xl bg-blue-600 group-hover:bg-blue-700 flex items-center justify-center transition-colors shadow-md shadow-blue-200">
              <CalcIcon icon={calc.icon} size={28} class="text-white" />
            </div>
          </div>
          <div class="text-xs font-semibold text-gray-700 group-hover:text-blue-700 leading-tight transition-colors">{calc.name}</div>
        </a>
      ))}
    </div>
  </section>

  <!-- Browse by Category -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-xl font-bold text-gray-900 mb-6">Browse by Category</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {categories.map(cat => (
        <a href={`/calculators/${cat.slug}`} class={`border rounded-2xl p-6 transition-all duration-200 hover:shadow-xl hover:-translate-y-1 group ${colorMap[cat.color]}`}>
          <div class="mb-4">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center group-hover:scale-105 transition-transform duration-200 shadow-sm"
              style={`background-color: ${cat.color === 'blue' ? '#2563eb' : cat.color === 'green' ? '#16a34a' : cat.color === 'purple' ? '#7c3aed' : '#d97706'}`}>
              <CalcIcon icon={cat.icon} size={28} class="text-white" />
            </div>
          </div>
          <div class="font-bold text-gray-900 text-base mb-0.5">{cat.name}</div>
          <div class="text-xs text-gray-500 mb-4 font-medium">{cat.calculators.filter(c => c.live).length} calculators</div>
          <div class="flex flex-wrap gap-1.5">
            {cat.calculators.filter(c => c.live).slice(0, 4).map(c => (
              <span class="text-xs bg-white/80 border border-gray-200/80 rounded-full px-2.5 py-0.5 text-gray-600 font-medium shadow-sm">{c.name.replace(' Calculator', '')}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- AI Feature banner -->
  <section class="relative overflow-hidden bg-gradient-to-r from-amber-50 to-orange-50 border-y border-amber-200 py-12 px-4">
    <div class="absolute inset-0 opacity-30" style="background-image: radial-gradient(circle at 20% 50%, #fbbf24 0px, transparent 50%), radial-gradient(circle at 80% 50%, #f97316 0px, transparent 50%); filter: blur(60px);"></div>
    <div class="relative max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center justify-center w-12 h-12 bg-amber-100 border border-amber-200 rounded-2xl mb-4 shadow-sm text-amber-600">
        <CalcIcon icon="✨" size={24} class="text-amber-600" />
      </div>
      <h2 class="text-xl font-bold text-amber-900 mb-2">AI-Powered Explanations</h2>
      <p class="text-sm text-amber-800 max-w-xl mx-auto leading-relaxed">Every calculator includes an "Explain this result" button. Get a plain-English breakdown of what your result means and what to do next — powered by AI.</p>
    </div>
  </section>

  <!-- About / AEO content -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">What is Super Calculator?</h2>
    <div class="grid md:grid-cols-3 gap-6 mb-12">
      {[
        { icon: '💰', heading: 'Financial Calculators', body: 'Mortgage payments, compound interest, loan schedules, retirement projections, and 45+ more financial tools. Every result includes a full breakdown so you understand where the numbers come from.' },
        { icon: '🏃', heading: 'Fitness & Health Calculators', body: 'BMI, calorie needs, TDEE, body fat percentage, macros, heart rate zones, and 25+ more health tools. Results follow WHO and ACSM guidelines for accuracy.' },
        { icon: '📐', heading: 'Math & Everyday Calculators', body: 'Percentages, fractions, unit conversions, statistics, date and time tools, GPA, tip calculator, and 60+ more utilities for school, work, and daily life.' },
      ].map(item => (
        <div class="bg-white border border-gray-200 rounded-xl p-6">
          <div class="text-3xl mb-3">{item.icon}</div>
          <h3 class="font-bold text-gray-900 mb-2 text-base">{item.heading}</h3>
          <p class="text-sm text-gray-600 leading-relaxed">{item.body}</p>
        </div>
      ))}
    </div>

    <div class="bg-gray-50 border border-gray-200 rounded-2xl p-8">
      <h2 class="text-lg font-bold text-gray-900 mb-4">How Super Calculator Works</h2>
      <div class="grid sm:grid-cols-2 gap-6 text-sm text-gray-700 leading-relaxed">
        <div>
          <p class="font-semibold text-gray-900 mb-1">Instant, free, and private</p>
          <p>Every calculation runs entirely in your browser. No sign-up, no account, no data sent to a server. Results are immediate.</p>
        </div>
        <div>
          <p class="font-semibold text-gray-900 mb-1">Step-by-step breakdowns</p>
          <p>Every result shows a full breakdown — inputs used, formula applied, and what each number means — so you can verify and understand your answer.</p>
        </div>
        <div>
          <p class="font-semibold text-gray-900 mb-1">AI explanations included</p>
          <p>After calculating, tap "Explain this result" to get a plain-English summary of what your number means and what to do next.</p>
        </div>
        <div>
          <p class="font-semibold text-gray-900 mb-1">Accurate formulas</p>
          <p>Financial calculators use standard amortization math. Health calculators follow WHO and peer-reviewed guidelines. Math tools use IEEE-standard arithmetic.</p>
        </div>
      </div>
    </div>

    <!-- FAQ for homepage AEO -->
    <div class="mt-10">
      <h2 class="text-lg font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {[
          { q: 'Are all calculators free?', a: 'Yes. Every calculator on Super Calculator is completely free to use with no sign-up, subscription, or account required.' },
          { q: 'Are the calculations accurate?', a: 'Yes. Financial calculators use standard amortization and investment formulas. Health calculators follow WHO, CDC, and ACSM guidelines. Each calculator page explains the formula used.' },
          { q: 'Is my data private?', a: 'All calculations run entirely in your browser. No inputs or results are sent to our servers. Your data stays on your device.' },
          { q: 'How many calculators are available?', a: 'Super Calculator currently offers 135+ free calculators across financial, fitness & health, math, and everyday life categories, with more added regularly.' },
          { q: 'Can I use Super Calculator on mobile?', a: 'Yes. Every calculator is fully responsive and works on any device — phone, tablet, or desktop — with no app download required.' },
        ].map(faq => (
          <details class="bg-white border border-gray-200 rounded-lg px-4 py-3 group">
            <summary class="text-sm font-medium text-gray-800 cursor-pointer list-none flex justify-between items-center">
              {faq.q}
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform shrink-0 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <p class="mt-2 text-sm text-gray-600 leading-relaxed">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Are all calculators free?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Every calculator on Super Calculator is completely free to use with no sign-up, subscription, or account required." } },
      { "@type": "Question", "name": "Are the calculations accurate?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Financial calculators use standard amortization and investment formulas. Health calculators follow WHO, CDC, and ACSM guidelines." } },
      { "@type": "Question", "name": "Is my data private?", "acceptedAnswer": { "@type": "Answer", "text": "All calculations run entirely in your browser. No inputs or results are sent to our servers. Your data stays on your device." } },
      { "@type": "Question", "name": "How many calculators are available?", "acceptedAnswer": { "@type": "Answer", "text": "Super Calculator currently offers 135+ free calculators across financial, fitness & health, math, and everyday life categories." } },
      { "@type": "Question", "name": "Can I use Super Calculator on mobile?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Every calculator is fully responsive and works on any device — phone, tablet, or desktop — with no app download required." } },
    ]
  })} />
</Layout>

<script define:vars={{ allCalcs }}>
  const input = document.getElementById('hero-search')
  const dropdown = document.getElementById('search-dropdown')

  input?.addEventListener('input', () => {
    const q = input.value.trim().toLowerCase()
    if (!q) { dropdown.classList.add('hidden'); return }
    const matches = allCalcs.filter(c => c.name.toLowerCase().includes(q))
    if (!matches.length) {
      dropdown.innerHTML = '<div class="px-4 py-3 text-sm text-gray-400">No calculators found</div>'
      dropdown.classList.remove('hidden')
      return
    }
    dropdown.innerHTML = matches.map(c =>
      `<a href="${c.href}" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-700 border-b border-gray-100 last:border-0" role="option">${c.name}</a>`
    ).join('')
    dropdown.classList.remove('hidden')
  })

  document.addEventListener('click', (e) => {
    if (!input?.contains(e.target) && !dropdown?.contains(e.target)) {
      dropdown?.classList.add('hidden')
    }
  })

  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') dropdown?.classList.add('hidden')
  })
</script>
