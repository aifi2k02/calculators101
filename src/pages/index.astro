---
import Layout from '../layouts/Layout.astro'
import { categories } from '../lib/calculators'
import siteConfig from '../lib/siteConfig'

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteConfig.siteName,
  url: siteConfig.siteUrl,
  description: siteConfig.siteDescription,
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${siteConfig.siteUrl}/?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
}

const popularCalcs = [
  { name: 'Mortgage Calculator', href: '/calculators/mortgage-calculator', icon: '🏠' },
  { name: 'BMI Calculator', href: '/calculators/bmi-calculator', icon: '⚖️' },
  { name: 'Tip Calculator', href: '/calculators/tip-calculator', icon: '🍽️' },
  { name: 'Age Calculator', href: '/calculators/age-calculator', icon: '🎂' },
  { name: 'Percentage Calculator', href: '/calculators/percentage-calculator', icon: '📊' },
  { name: 'Compound Interest', href: '/calculators/compound-interest-calculator', icon: '📈' },
  { name: 'Calorie Calculator', href: '/calculators/calorie-calculator', icon: '🥗' },
  { name: 'Loan Calculator', href: '/calculators/loan-calculator', icon: '💳' },
  { name: 'GPA Calculator', href: '/calculators/gpa-calculator', icon: '🎓' },
  { name: 'Date Calculator', href: '/calculators/date-calculator', icon: '📅' },
]

const colorMap: Record<string, string> = {
  blue: 'bg-blue-50 border-blue-200 hover:border-blue-400',
  green: 'bg-green-50 border-green-200 hover:border-green-400',
  purple: 'bg-purple-50 border-purple-200 hover:border-purple-400',
  amber: 'bg-amber-50 border-amber-200 hover:border-amber-400',
}

// Only show live calculators in search
const allCalcs = categories.flatMap(c => c.calculators.filter(calc => calc.live))
---

<Layout
  title="Free Online Calculators — Finance, Fitness, Math & More"
  description="Free online calculators for finance, fitness, math, and everyday life. Mortgage, BMI, calorie, loan, TDEE, and 130+ more — fast, accurate, no sign-up required."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-blue-600 to-blue-800 text-white py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-4 leading-tight">
        Free Online Calculators
      </h1>
      <p class="text-blue-100 text-lg sm:text-xl mb-8 max-w-2xl mx-auto">
        Fast, accurate calculators for finance, fitness, math, and everyday life. No sign-up. No ads. Just results.
      </p>
      <div class="max-w-lg mx-auto relative">
        <input
          id="hero-search"
          type="text"
          placeholder="Search calculators..."
          class="w-full px-5 py-3.5 pr-12 rounded-xl text-white placeholder-white/70 bg-white/20 text-sm focus:outline-none focus:ring-2 focus:ring-white/50 shadow-lg"
          autocomplete="off"
          aria-label="Search calculators"
        />
        <svg class="absolute right-4 top-3.5 w-5 h-5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <div id="search-dropdown" class="hidden absolute top-full left-0 right-0 mt-1 bg-white rounded-xl shadow-xl border border-gray-200 z-50 max-h-64 overflow-y-auto" role="listbox"></div>
      </div>
    </div>
  </section>

  <!-- Most Popular -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-xl font-bold text-gray-900 mb-5">Most Popular</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
      {popularCalcs.map(calc => (
        <a
          href={calc.href}
          class="bg-white border border-gray-200 hover:border-blue-300 hover:shadow-md rounded-xl p-4 text-center transition-all group"
        >
          <div class="text-2xl mb-2">{calc.icon}</div>
          <div class="text-xs font-medium text-gray-700 group-hover:text-blue-700 leading-tight">{calc.name}</div>
        </a>
      ))}
    </div>
  </section>

  <!-- Browse by Category -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-xl font-bold text-gray-900 mb-5">Browse by Category</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {categories.map(cat => (
        <a href={`/calculators/${cat.slug}`} class={`border rounded-xl p-5 transition-all hover:shadow-md ${colorMap[cat.color]}`}>
          <div class="text-3xl mb-2">{cat.icon}</div>
          <div class="font-bold text-gray-900">{cat.name}</div>
          <div class="text-xs text-gray-500 mb-3">{cat.calculators.filter(c => c.live).length} calculators live</div>
          <div class="flex flex-wrap gap-1">
            {cat.calculators.filter(c => c.live).slice(0, 4).map(c => (
              <span class="text-xs bg-white/70 border border-gray-200 rounded-full px-2 py-0.5 text-gray-600">{c.name.replace(' Calculator', '')}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- AI Feature banner -->
  <section class="bg-amber-50 border-y border-amber-200 py-10 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <div class="text-3xl mb-2">✨</div>
      <h2 class="text-lg font-bold text-amber-900 mb-2">AI-Powered Explanations</h2>
      <p class="text-sm text-amber-800 max-w-xl mx-auto">Every calculator includes an "Explain this result" button. Get a plain-English breakdown of what your result means and what to do next — powered by AI.</p>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
</Layout>

<script define:vars={{ allCalcs }}>
  const input = document.getElementById('hero-search')
  const dropdown = document.getElementById('search-dropdown')

  input?.addEventListener('input', () => {
    const q = input.value.trim().toLowerCase()
    if (!q) { dropdown.classList.add('hidden'); return }
    const matches = allCalcs.filter(c => c.name.toLowerCase().includes(q))
    if (!matches.length) {
      dropdown.innerHTML = '<div class="px-4 py-3 text-sm text-gray-400">No calculators found</div>'
      dropdown.classList.remove('hidden')
      return
    }
    dropdown.innerHTML = matches.map(c =>
      `<a href="${c.href}" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-700 border-b border-gray-100 last:border-0" role="option">${c.name}</a>`
    ).join('')
    dropdown.classList.remove('hidden')
  })

  document.addEventListener('click', (e) => {
    if (!input?.contains(e.target) && !dropdown?.contains(e.target)) {
      dropdown?.classList.add('hidden')
    }
  })

  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') dropdown?.classList.add('hidden')
  })
</script>
